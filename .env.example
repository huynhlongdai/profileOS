# ============================================
# ProfileOS Environment Configuration
# ============================================

# --- Database (Supabase PostgreSQL) ---
# Supabase connection pooler URL (for serverless/Vercel)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection URL (for migrations)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# --- GPMLogin API ---
# Default GPMLogin API URL (local or via Tailscale)
# Local: http://127.0.0.1:19995
# Via Tailscale: http://100.x.x.x:19995
GPMLOGIN_API_URL="http://127.0.0.1:19995"
GPMLOGIN_API_VERSION="v3"

# --- Auto Registration Service ---
# Local: http://127.0.0.1:8000
# Via Tailscale: http://100.x.x.x:8000
AUTO_REG_URL="http://127.0.0.1:8000"

# --- Local Agent (GPM Controller via Tailscale) ---
# Tailscale IP of the local machine running GPMLogin
# Leave empty if running locally
LOCAL_AGENT_URL=""
# Shared secret for agent authentication
AGENT_SECRET=""

# --- Authentication ---
# Set a password to protect the dashboard (leave empty to disable auth)
AUTH_PASSWORD=""

# --- App Configuration ---
# Base URL of the deployed app (for webhooks, callbacks)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Node environment
NODE_ENV="development"

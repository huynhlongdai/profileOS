# ProfileOS Local Agent Configuration

# ProfileOS server URL (Vercel deployment)
PROFILEOS_URL=https://your-app.vercel.app

# Agent secret (must match AGENT_SECRET on Vercel)
AGENT_SECRET=your-agent-secret

# Poll interval in milliseconds (default: 5000 = 5 seconds)
POLL_INTERVAL=5000

# === Browser Providers ===

# GPMLogin (phiên bản mới, v3 API)
GPMLOGIN_API_URL=http://127.0.0.1:19995
GPMLOGIN_API_VERSION=v3

# GPMGlobal (v1 API)
GPMGLOBAL_API_URL=http://127.0.0.1:9495
GPMGLOBAL_API_VERSION=v1

# Chrome (optional - auto-detects path if not set)
# CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# Firefox (optional - auto-detects path if not set)
# FIREFOX_PATH=C:\Program Files\Mozilla Firefox\firefox.exe

# ProfileOS Local Agent Configuration

# URL of the deployed ProfileOS dashboard
PROFILEOS_URL=https://your-app.vercel.app

# Shared secret for agent authentication (must match AGENT_SECRET on server)
AGENT_SECRET=your-shared-secret-here

# GPMLogin API URL (local)
GPMLOGIN_API_URL=http://127.0.0.1:19995
GPMLOGIN_API_VERSION=v3

# Poll interval in milliseconds (default: 5000 = 5 seconds)
POLL_INTERVAL=5000

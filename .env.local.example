# ============================================
# ProfileOS Local Mode (SQLite)
# ============================================
# Copy this to .env to use local SQLite database
# Fastest option — 0 network latency

# --- Database (SQLite Local) ---
DATABASE_URL="file:./dev.db"

# --- GPMLogin API ---
GPMLOGIN_API_URL="http://127.0.0.1:19995"
GPMLOGIN_API_VERSION="v3"

# --- Auto Registration Service ---
AUTO_REG_URL="http://127.0.0.1:8000"

# --- Local Agent ---
LOCAL_AGENT_URL=""
AGENT_SECRET="profileos-agent-2024-secret-key"

# --- Authentication ---
# Set password to protect dashboard (leave empty to skip login)
AUTH_PASSWORD=""

# --- App Configuration ---
NEXT_PUBLIC_APP_URL="http://localhost:3211"
NODE_ENV="development"
